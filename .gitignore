# ─── Local environment ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
VAULT.env

# ─── Demo / evolve / iterate output (generated artifacts) ───────────────
forge-demo-*/
forge-evolve-*/
forge-iterate-*/

# ─── Out-of-scope sister projects (live in their own repos) ─────────────
# These directories are tracked in separate repositories and must NEVER
# be re-added to atomadic-forge:
#   * Tauri GUI         → atomadic-forge-tauri-studio
#   * Web app           → atomadic-forge-site
#   * VS Code extension → atomadic-forge-vscode-ext
#   * Cloudflare Worker → atomadic-forge-cloudflare-workers
#   * Investor site     → atomadic-investor-site
forge-studio/
forge-web/
vscode-forge-extension/
cloudflare-workers/
packages/
investor-site/

# ─── JavaScript / Node tooling (atomadic-forge is pure Python) ──────────
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package.json
package-lock.json
pnpm-lock.yaml
pnpm-workspace.yaml
.npmrc
*.tsbuildinfo
coverage/
.nyc_output/

# ─── Rust / Tauri build artifacts (in case any sneak in) ────────────────
target/
Cargo.lock
*.rlib
*.rmeta

# ─── Cloudflare Wrangler ────────────────────────────────────────────────
.wrangler/

# ─── Binaries / installers (don't ship from this repo) ──────────────────
*.exe
*.msi
*.dmg
*.AppImage
*.deb
*.rpm
