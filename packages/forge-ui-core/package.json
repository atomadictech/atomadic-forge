{
  "name": "@atomadic/forge-ui-core",
  "version": "0.3.2",
  "private": true,
  "description": "Shared React UI core for Atomadic Forge — components, theme, types, ForgeClient abstraction",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/theme/theme.css",
    "./client": "./src/client/index.ts",
