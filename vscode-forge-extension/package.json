{
  "name": "atomadic-forge-vscode",
  "displayName": "Atomadic Forge",
  "description": "Live diagnostics + hover + goto-source for .forge sidecar files. Plugs into forge lsp serve.",
  "version": "0.3.1",
  "publisher": "atomadictech",
  "license": "BUSL-1.1",
  "homepage": "https://github.com/atomadictech/atomadic-forge",
  "bugs": {
    "url": "https://github.com/atomadictech/atomadic-forge/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/atomadictech/atomadic-forge.git",
    "directory": "vscode-forge-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "atomadic",
    "forge",
    "architecture",
    "monadic",
    "tier",
    "sidecar",
    "lsp"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:forge",
    "workspaceContains:**/*.py.forge",
    "workspaceContains:**/*.ts.forge",
    "workspaceContains:**/*.js.forge"
  ],
  "contributes": {
    "languages": [
      {
        "id": "forge",
        "aliases": ["Atomadic Forge sidecar", "forge"],
        "extensions": [".forge"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Atomadic Forge",
      "properties": {
        "atomadicForge.serverPath": {
          "type": "string",
          "default": "forge",
          "description": "Path to the forge executable. Default uses the system PATH."
        },
        "atomadicForge.serverArgs": {
          "type": "array",
          "default": ["lsp", "serve"],
          "items": { "type": "string" },
          "description": "Args passed to the forge executable to start the LSP."
        },
        "atomadicForge.trace.server": {
          "type": "string",
          "scope": "window",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces the communication between VS Code and the forge LSP server."
        }
      }
    },
    "commands": [
      {
        "command": "atomadicForge.restartServer",
        "title": "Atomadic Forge: Restart language server"
      },
      {
        "command": "atomadicForge.showOutput",
        "title": "Atomadic Forge: Show LSP output"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./out/test/runTest.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
